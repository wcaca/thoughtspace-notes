{
  "name": "thoughtspace-notes",
  "version": "0.0.0",
  "description": "念头空间 - 笔记路线: 笔记→念头→结构→觉察 的空间化思维整理工具",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx serve .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:arch": "node scripts/check-arch.mjs",
    "check:geb": "node scripts/check-geb.mjs",
    "check:notes": "node scripts/check-note-links.mjs",
    "check:topology": "node scripts/check-topology.mjs",
    "check:spec": "node scripts/check-spec-coverage.mjs",
    "check:spec-topology": "node scripts/check-spec-topology.mjs",
    "check:flag-topology": "node scripts/check-flag-topology.mjs",
    "check:non-negotiable": "node scripts/check-non-negotiable.mjs",
    "check:orphans": "node scripts/check-orphans.mjs",
    "check:typecheck": "node scripts/check-typecheck.mjs",
    "check:test-spec-linkage": "node scripts/check-test-spec-linkage.mjs",
    "check:spec-drift": "node scripts/check-spec-drift.mjs",
    "check:all": "npm run check:arch && npm run check:geb && npm run check:notes && npm run check:topology && npm run check:spec && npm run check:spec-topology && npm run check:flag-topology && npm run check:non-negotiable && npm run check:orphans && npm run check:typecheck && npm test && npm run check:test-spec-linkage && npm run check:spec-drift",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "geb:bootstrap": "node scripts/bootstrap.mjs",
    "holo:index": "node scripts/generate-holo-index.mjs",
    "holo:report": "node scripts/generate-holo-report.mjs",
    "generate:flag-registry": "node scripts/generate-flag-registry.mjs",
    "postinstall": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.0.0",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "pixi.js": "^8.19.0",
    "prettier": "^3.3.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "convex-hull": "^1.0.3",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "three": "^0.185.1",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.30"
  }
}
